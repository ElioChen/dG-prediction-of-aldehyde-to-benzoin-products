# Generated data (regenerable from the pipeline; too big / not source)
/data/labels/
/data/descriptors/
/data/library/*.parquet
/data/chunks/
/data/raw/
*.parquet

# Cross-benzoin featurization outputs (huge, inode-heavy, regenerable from homo_pairs.csv)
# Keep the small input manifests (homo_pairs.csv) tracked; ignore per-chunk results,
# xyz geometries, and concatenated tables.
/data/cross_benzoin/*/chunk_*/
/data/cross_benzoin/**/xyz_ald/
/data/cross_benzoin/**/xyz_prod/
/data/cross_benzoin/*/*_all.csv
/data/cross_benzoin/candidates_*/chunks_*/
*.xyz

# homo_v6 raw featurization dumps (multi-GB, regenerable via pipeline/compute/*.py +
# pipeline/slurm/submit_*.sh) -- keep the small manifests, reports, figures, and
# reasonably-sized prediction/result CSVs that live alongside them.
/data/cross_benzoin/homo_v6/*_descriptors.csv
/data/cross_benzoin/homo_v6/*_morfeus_extra.csv
/data/cross_benzoin/homo_v6/products_clean.csv
/data/cross_benzoin/homo_v6/*_aldehydes/
/data/cross_benzoin/homo_v6/*_products/
/data/cross_benzoin/homo_v6/mordred_pilot_test/
/data/cross_benzoin/homo_v6/bdfe_test_pilot/
/data/cross_benzoin/homo_v6_backfill/
*.pt

# Trained model bundles (regenerable via pipeline/analysis/finalize_*.py; many
# multi-hundred-MB joblib experiments accumulate here -- not source)
/pipeline/models/

# Scratch
/tmp/

# MLflow tracking store + artifacts
/mlflow.db
/mlartifacts/
/mlruns/

# Training outputs (the SHIPPED model lives in src/benzoin_dG/models/, not here)
/runs/

# SLURM logs / scratch
*.out
*.log
**/logs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Test / tooling caches
.pytest_cache/
.ruff_cache/

# Notebooks / editors
.ipynb_checkpoints/
.vscode/
.idea/

# OS
.DS_Store

# Old corrupted git object database, kept aside for forensics (2026-07-13) -- not source
/.git.corrupted-backup-20260713/

# Cross-benzoin round training tables >50MB (2026-07-20): the full un-slimmed mordred
# join (before shap_slim_cross_mordred.py's 423->120 prune) balloons these to
# 100MB-1GB+, well over GitHub's 100MB hard push limit -- regenerable from
# assemble_cross_training_table_v3.py / assemble_cross_round_features.py against the
# tracked source manifests, not source themselves. The parquet equivalents (already
# gitignored via *.parquet above) are what training/inference scripts actually read;
# these CSVs are a human-readable byproduct, safe to drop from git.
/data/cross_benzoin/*/cross_train_table_*rounds_mordred.csv
/data/cross_benzoin/homo_unify/cross_train_table_unified_v2_*.csv
/data/cross_benzoin/cross_round5/cross_train_table_5rounds_mordred_slim120.csv
/data/cross_benzoin/cross_round8/cross_round8_features.csv
/data/cross_benzoin/screen10k/screen10k_features_screen10k_products_final.csv
/data/cross_benzoin/screen10k/screen10k_products_mordred.csv
/data/cross_benzoin/homo_v6/aldehydes_mordred_slim102.csv
